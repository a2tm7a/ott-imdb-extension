{
  "manifest_version": 3,
  "name": "IMDB Ratings for OTT",
  "version": "1.0.0",
  "description": "Overlay IMDB ratings on Netflix, Prime Video, Hotstar and more.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.netflix.com/*",
    "*://*.primevideo.com/*",
    "*://*.amazon.com/*",
    "*://*.hotstar.com/*",
    "*://www.omdbapi.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; style-src 'self'; connect-src https://www.omdbapi.com;"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["content-scripts/base-adapter.js", "content-scripts/netflix.js"],
      "css": ["styles/badge.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.primevideo.com/*", "*://*.amazon.com/*/video/*", "*://*.amazon.com/gp/video/*"],
      "js": ["content-scripts/base-adapter.js", "content-scripts/prime.js"],
      "css": ["styles/badge.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.hotstar.com/*"],
      "js": ["content-scripts/base-adapter.js", "content-scripts/hotstar.js"],
      "css": ["styles/badge.css"],
      "run_at": "document_idle"
    },
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "theme_icons": [
      {
        "light": "icons/icon16_light.png",
        "dark": "icons/icon16_dark.png",
        "size": 16
      },
      {
        "light": "icons/icon48_light.png",
        "dark": "icons/icon48_dark.png",
        "size": 48
      },
      {
        "light": "icons/icon128_light.png",
        "dark": "icons/icon128_dark.png",
        "size": 128
      }
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
